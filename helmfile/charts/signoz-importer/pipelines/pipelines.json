      "updatedAt":
       "0001-01-01T00:00:00Z",
      "id": "019c8b36-850c-72cb-902c-d572a83aad25",
      "orderId": 1,
      "enabled": true,
      "name": "Notify Admin Requests",
      "alias": "bentest",
      "description": "",
      "filter": {
        "op": "AND",
        "items": [
          {
            "key": {
              "key": "k8s.deployment.name",
              "dataType": "string",
              "type": "resource",
              "isColumn": false,
              "isJSON": false
            },
            "value": "notify-admin",
            "op": "="
          },
          {
            "key": {
              "key": "body",
              "dataType": "string",
              "type": "",
              "isColumn": true,
              "isJSON": false
            },
            "value": "^\\d{1,3}(?:\\.\\d{1,3}){3}\\s+-\\s+-\\s+\\[\\d{2}\\/[A-Za-z]{3}\\/\\d{4}:\\d{2}:\\d{2}:\\d{2}\\s+[+-]\\d{4}\\]\\s+\"[A-Z]+\\s+\\S+\\s+HTTP\\/\\d\\.\\d\"\\s+\\d{3}\\s+\\d+\\s+\"[^\"]*\"\\s+\"[^\"]*\"\\s*$",
            "op": "regex"
          }
        ]
      },
      "config": [
        {
          "type": "regex_parser",
          "id": "e573a576-b59d-4ca6-b9ae-c84977024e47",
          "on_error": "send",
          "orderId": 1,
          "enabled": true,
          "name": "Notify Admin Request Regex",
          "parse_to": "attributes",
          "regex": "^(?<client_ip>\\S+)\\s+(?<ident>\\S+)\\s+(?<auth_user>\\S+)\\s+\\[(?<timestamp>[^\\]]+)\\]\\s+\"(?<method>[A-Z]+)\\s+(?<request_uri>[^ ]+)\\s+HTTP\\/(?<http_version>[0-9.]+)\"\\s+(?<status>\\d{3})\\s+(?<bytes>\\d+)\\s+\"(?<referer>[^\"]*)\"\\s+\"(?<user_agent>[^\"]*)\"\\s*$",
          "parse_from": "body"
        }
      ]
    },
    {
      "createdBy": "ben.larabie@cds-snc.ca",
      "updatedBy": "",
      "createdAt": "2026-03-04T18:23:29.354378Z",
