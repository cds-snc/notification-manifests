      "id": "019cba17-364f-74e5-89a0-b2ad715e6089",
      "orderId": 5,
      "enabled": true,
      "name": "Notify Celery Logs",
      "alias": "NotifyCeleryLogs",
      "description": "",
      "filter": {
        "op": "AND",
        "items": [
          {
            "key": {
              "key": "k8s.deployment.name",
              "dataType": "string",
              "type": "resource",
              "isColumn": false,
              "isJSON": false
            },
            "value": "notify-celery",
            "op": "contains"
          },
          {
            "key": {
              "key": "body",
              "dataType": "string",
              "type": "",
              "isColumn": true,
              "isJSON": false
            },
            "value": "^\\[\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2},\\d{3}:\\s+[A-Z]+\\/[^\\]]+\\]\\s+.+$",
            "op": "regex"
          }
        ]
      },
      "config": [
        {
          "type": "regex_parser",
          "id": "245fe9ee-5265-47f0-8930-6a4f8362a50a",
          "on_error": "send",
          "orderId": 1,
          "enabled": true,
          "name": "Celery Regex Parser",
          "parse_to": "attributes",
          "regex": "^\\[(?<timestamp>\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2},\\d{3}):\\s+(?<levelname>[A-Z]+)\\/(?<worker>[^\\]]+)\\]\\s+(?<message>.*)$",
          "parse_from": "body"
        }
      ]
    },
