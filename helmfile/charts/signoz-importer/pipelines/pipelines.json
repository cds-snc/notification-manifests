              "type": "",
              "isColumn": true,
              "isJSON": false
            },
            "value": "^{",
            "op": "regex"
          }
        ]
      },
      "config": [
        {
          "type": "json_parser",
          "id": "3abd011b-14bb-4b61-9639-0fb28867ad41",
          "output": "c2f9e085-ea71-44c6-83dc-0c94f6e2c5b5",
          "orderId": 1,
          "enabled": true,
          "name": "Notify Admin JSON Parser",
          "parse_to": "attributes",
          "parse_from": "body"
        },
        {
          "type": "regex_parser",
          "id": "c2f9e085-ea71-44c6-83dc-0c94f6e2c5b5",
          "output": "d25b3097-e01f-4d9d-bdf9-6d7a56ab26d1",
          "on_error": "send",
          "orderId": 2,
          "enabled": true,
          "name": "Notify Admin Time Taken Parser",
          "parse_to": "attributes",
          "regex": "Request details:\\s*time_taken:\\s*(?<time_taken>\\d+(?:\\.\\d+)?)ms",
          "parse_from": "body"
        },
        {
          "type": "regex_parser",
          "id": "d25b3097-e01f-4d9d-bdf9-6d7a56ab26d1",
          "output": "caf7f4ab-b10b-4b78-961c-59b8dc28bddb",
          "on_error": "send",
          "orderId": 3,
          "enabled": true,
          "name": "Notify admin full path parser",
          "parse_to": "attributes",
          "regex": "full_path:\\s*'(?P<full_path>[^']+)'",
          "parse_from": "body"
        },
        {
          "type": "regex_parser",
          "id": "caf7f4ab-b10b-4b78-961c-59b8dc28bddb",
          "on_error": "send",
          "orderId": 4,
          "enabled": true,
          "name": "Notify admin endpoint parser",
          "parse_to": "attributes",
          "regex": "endpoint:\\s*'(?P<endpoint>[^']+)'",
          "parse_from": "body"
        }
      ]
    },
