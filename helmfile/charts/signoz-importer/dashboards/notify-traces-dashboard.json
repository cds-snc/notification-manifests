  "id": "gcn-frontend-page-load-traces",
  "layout": [
    { "h": 6, "i": "panel-volume",     "moved": false, "static": false, "w": 6,  "x": 0, "y": 0  },
    { "h": 6, "i": "panel-duration",   "moved": false, "static": false, "w": 6,  "x": 6, "y": 0  },
    { "h": 6, "i": "panel-by-section", "moved": false, "static": false, "w": 6,  "x": 0, "y": 6  },
    { "h": 6, "i": "panel-nav-type",   "moved": false, "static": false, "w": 6,  "x": 6, "y": 6  },
    { "h": 6, "i": "panel-dom-timing", "moved": false, "static": false, "w": 6,  "x": 0, "y": 12 },
    { "h": 6, "i": "panel-ttfb",       "moved": false, "static": false, "w": 6,  "x": 6, "y": 12 },
    { "h": 8, "i": "panel-by-path",    "moved": false, "static": false, "w": 12, "x": 0, "y": 18 }
  ],
  "tags": ["otel", "frontend", "browser", "traces"],
  "title": "GC Notify — Frontend Page Load Traces",
  "widgets": [
    {
      "description": "Number of browser.page_load spans recorded per minute",
      "fillSpans": false,
      "id": "panel-volume",
      "isStacked": false,
      "nullZeroValues": "zero",
      "opacity": "1",
      "panelTypes": "graph",
      "query": {
        "builder": {
          "queryData": [
            {
              "aggregateAttribute": {
                "dataType": "float64",
                "id": "durationNano--float64--tag--true",
                "isColumn": true,
                "isJSON": false,
                "key": "durationNano",
                "type": "tag"
              },
              "aggregateOperator": "count",
              "dataSource": "traces",
              "disabled": false,
              "expression": "A",
              "filters": {
                "items": [
                  {
                    "id": "f-vol-name",
                    "key": {
                      "dataType": "string",
                      "id": "name--string--tag--true",
                      "isColumn": true,
                      "isJSON": false,
                      "key": "name",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "browser.page_load"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [],
              "having": [],
              "legend": "Page Loads / min",
              "limit": null,
              "orderBy": [],
              "queryName": "A",
              "reduceTo": "sum",
              "stepInterval": 60
            }
          ],
          "queryFormulas": []
        },
        "clickhouse_sql": [{ "disabled": true, "legend": "", "name": "A", "query": "" }],
        "id": "q-volume",
        "promql": [{ "disabled": true, "legend": "", "name": "A", "query": "" }],
        "queryType": "builder"
      },
      "softMax": null,
      "softMin": null,
      "timePreference": "GLOBAL_TIME",
      "title": "Page Load Volume",
      "yAxisUnit": "short"
    },

